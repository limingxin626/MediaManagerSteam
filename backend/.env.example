# backend 配置 —— 复制本文件为 backend/.env 后按需修改。
# backend/.env 已被 .gitignore 忽略,放心写本机绝对路径。
#
# 加载规则:app.config 在 import 时 load_dotenv(override=False) 读本文件。
# 真实环境变量 / `python api.py --data-root ...` 优先于这里(override=False)。
# 因为 app.models → app.config,api.py / alembic / scripts/* 全部自动跟随,无需各自配。

# ── 当前 instance ──────────────────────────────────────────────
# 同一时刻只留一行 DATA_ROOT 生效;切 instance = 注释当前行、放开目标行,重启进程。
# 各 instance 完全独立:自己的 db.sqlite3 / repositories.json / thumbs 都在 DATA_ROOT 下。
# 路径用 forward-slash(Windows 也认),避免反斜杠转义。
DATA_ROOT=C:/Users/jieli4/Desktop/Code/MediaManagerSteam/backend/Data
# DATA_ROOT=D:/Note/notes2          # 第二套笔记库示例:切到它就注释上面、放开本行

# ── 服务 ───────────────────────────────────────────────────────
# HOST=0.0.0.0
PORT=8002

# ── ffmpeg / ffprobe(留空走 PATH;装在非标准位置时填绝对路径)──
# FFMPEG_PATH=
# FFPROBE_PATH=

# ── Telegram "Saved Messages" 同步(不用可全部留空/删掉)──────
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_POLL_INTERVAL=60
# TELEGRAM_LARGE_FILE_THRESHOLD=52428800
